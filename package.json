{
  "name": "megastore-simulator-vortex-extension",
  "version": "1.3.3",
  "description": "Vortex support for Megastore Simulator",
  "license": "MPL-2.0",
  "author": "toebeann",
  "homepage": "https://github.com/toebeann/megastore-simulator-vortex-extension",
  "repository": {
    "type": "git",
    "url": "https://github.com/toebeann/megastore-simulator-vortex-extension.git"
  },
  "bugs": {
    "url": "https://github.com/toebeann/megastore-simulator-vortex-extension/issues"
  },
  "config": {
    "issueTracker": "https://github.com/toebeann/megastore-simulator-vortex-extension/issues"
  },
  "funding": [
    "https://github.com/toebeann/megastore-simulator-vortex-extension?sponsor=1",
    {
      "type": "github",
      "url": "https://github.com/sponsors/toebeann"
    },
    {
      "type": "kofi",
      "url": "https://ko-fi.com/toebean_"
    },
    {
      "type": "paypal",
      "url": "https://paypal.me/tobeyblaber"
    }
  ],
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "tpk": "bun build/tpk",
    "winget": "bun build/winget",
    "preprepare": "rm -r DotNetUtils/bin || true",
    "prepare": "bun --parallel tpk build:dotnet install:7zip",
    "install:7zip": "where 7z >/dev/null || bun winget 7zip.7zip --no-upgrade",
    "install:dotnet": "powershell -NoProfile -NoLogo -NonInteractive -c 'if (((dotnet --list-sdks | select-string ^9. | select -expand line) | measure-object | select -expand count) -lt 1) { bun winget Microsoft.DotNet.SDK.9 --no-upgrade }'",
    "prebuild:dotnet": "bun install:dotnet",
    "build:dotnet": "dotnet build -c Release ./DotNetUtils",
    "prebuild": "bun --parallel 'rm -r dist; mkdir dist; extractInfo' 'bun build:dotnet -p:GenerateNodeApiTypeDefinitionsForReferences=false' tpk",
    "build": "bun build/",
    "postbuild": "bun 7z",
    "pre7z": "rm $npm_package_name.7z* 2>/dev/null; cp LICENSE ./dist/LICENSE",
    "7z": "7z a -t7z -x!meta.md $npm_package_name.7z ./dist/*",
    "dev": "bun run build --features DEVTOOLS --no-minify",
    "prerelease": "bun tpk --update",
    "release": "bun run build --drop console --drop debugger --no-sourcemap"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "fast-glob": "^3.3.3",
    "isbinaryfile": "^6.0.0",
    "lodash": "^4.18.1",
    "shell-quote": "^1.8.3",
    "store2": "^2.14.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nexusmods/nexus-api": "^1.1.5",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/bun": "1.3.12",
    "@types/fs-extra": "^9.0.13",
    "@types/lodash": "^4.17.24",
    "@types/semver": "^7.7.1",
    "@types/shell-quote": "^1.7.5",
    "jszip": "^3.10.1",
    "node-api-dotnet": "^0.9.19",
    "steam-acf-parser": "github:mattb-prg/steam-acf-parser",
    "vortex-api": "github:Nexus-Mods/vortex-api"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "bun": "^1.3.12"
  },
  "os": ["win32"]
}
